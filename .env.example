# DeepSeek API key — get one at https://platform.deepseek.com/
# Leave empty to use the local mock model instead.
DEEPSEEK_API_KEY=
EMBED_API_KEY=

# Tavily Search API key — used by web_search when configured.
# Takes priority over SERPER_API_KEY.
TAVILY_API_KEY=

# Serper API key — fallback Google search provider when TAVILY_API_KEY is empty.
SERPER_API_KEY=

# GitHub Personal Access Token — used by @modelcontextprotocol/server-github MCP server.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Feishu channel plugin — first enable channels.feishu in the JSON config.
# Leave APP_ID / APP_SECRET empty for Dashboard-only mode. The configured
# channel uses its JSON port; FEISHU_PORT remains the manual plugin default.
FEISHU_PORT=3000
FEISHU_APP_ID=
FEISHU_APP_SECRET=
